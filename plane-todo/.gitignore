# Dependencies
node_modules/
**/node_modules/

# Build outputs and generated bundles
# NOTE: do not add a bare `lib/` here — it would ignore real source such as
# apps/mobile/src/lib/. All packages build to dist/, not lib/.
dist/
build/
out/
coverage/
.turbo/
.tsbuildinfo
*.tsbuildinfo

# Expo / React Native local state
.expo/
.expo-shared/
.eas/
web-build/
android/
ios/
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Environment and secret files
.env
.env.*
!.env.example
!.env.*.example
ignore.text

# Local databases and runtime data
/data/
/apps/notifier/data/
*.db
*.db-*
*.sqlite
*.sqlite3

# Logs and diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
