# --- Plane (required) ---
PLANE_BASE_URL=https://plane.your-company.example
PLANE_WORKSPACE_SLUG=your-workspace-slug
PLANE_API_KEY=plane_api_xxxxxxxxxxxxxxxxxxxx
# Comma-separated list of project IDs to track
PLANE_PROJECT_IDS=00000000-0000-0000-0000-000000000000
# Shared secret configured on the Plane webhook (required)
PLANE_WEBHOOK_SECRET=change-me

# --- SMTP / email (optional; email is skipped cleanly if HOST/FROM/TO absent) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=

# --- Service ---
# IANA timezone for the 5-minute cron; digest uses config.json digest.tz
TZ=UTC
PORT=3005
# SQLite file location (default ./data/notifier.db)
DB_PATH=./data/notifier.db
# Path to reminder-offset config (default ./config.json)
CONFIG_PATH=./config.json
