{
  "name": "@plane-todo/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "Expo/React Native client for Plane work items (expo-router).",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node ./scripts/link-expo-router.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc -p tsconfig.verify.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@plane-todo/core": "workspace:*",
    "@react-native-community/datetimepicker": "8.4.4",
    "@tanstack/react-query": "^5.51.0",
    "expo": "~54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "typescript": "~5.9.2",
    "vitest": "^2.0.5"
  }
}
