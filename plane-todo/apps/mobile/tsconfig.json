{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "lib": [
      "ES2021",
      "DOM"
    ],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowJs": true
  },
  "include": [
    "src",
    "app"
  ]
}
