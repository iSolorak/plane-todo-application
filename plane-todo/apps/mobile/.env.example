# Copy to `.env` (gitignored) and fill in your own values.
# Read by app.config.js and injected into the Expo config at build time.
# The mobile app doesn't otherwise read process.env at runtime — Plane
# credentials are entered on the in-app setup screen and stored via
# expo-secure-store.

# Your Expo project id UUID.
# Find it at: https://expo.dev/accounts/<you>/projects/<slug>/settings
# Or create/link one with:  pnpm exec eas init
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Expo account / organization slug that owns the project (required by EAS).
EAS_OWNER=your-expo-username

# Optional: path to Firebase google-services.json for Android FCM push.
# Defaults to ./google-services.json when omitted (see ./credentials/README.md).
# GOOGLE_SERVICES_JSON=./google-services.json
