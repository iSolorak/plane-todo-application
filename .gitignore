# Local Codex/agent workspace metadata
.agents/
.codex/

# Dependencies
node_modules/
**/node_modules/

# Build outputs and generated bundles
# NOTE: do not add a bare `lib/` here — it would ignore real source such as
# apps/mobile/src/lib/. All packages build to dist/, not lib/.
dist/
build/
out/
coverage/
.turbo/
.tsbuildinfo
*.tsbuildinfo

# Expo / React Native local state
.expo/
.expo-shared/
.eas/
web-build/
android/
ios/
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Firebase / FCM credentials
#
# NOTE: `google-services.json` (Android) and `GoogleService-Info.plist` (iOS)
# are NOT real secrets — they're embedded in every APK/IPA you distribute and
# Google explicitly documents their API keys as safe to expose (secured by
# SHA-1 + package-name restrictions on the Cloud side, not by hiding the file).
# We intentionally TRACK apps/mobile/google-services.json so EAS builds are
# reproducible without extra secret-management setup. Real Firebase security
# lives in Security Rules + App Check.
#
# The service-account key IS a secret and stays ignored below.
google-services.json
!apps/mobile/google-services.json
!plane-todo/apps/mobile/google-services.json
GoogleService-Info.plist
**/credentials/*.json
!**/credentials/*.example.json
# Belt-and-braces: Firebase admin SDK service-account keys have a
# recognizable naming pattern (`<project>-firebase-adminsdk-<hash>.json`);
# ignore them anywhere in the tree so a stray copy can never be committed.
*-firebase-adminsdk-*.json

# Environment and secret files
.env
.env.*
!.env.example
!.env.*.example
ignore.text
**/ignore.text

# Local databases and runtime data
/data/
/plane-todo/data/
/plane-todo/apps/notifier/data/
*.db
*.db-*
*.sqlite
*.sqlite3

# Logs and diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
